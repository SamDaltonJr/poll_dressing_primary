rules_version = '2';

// Photos uploaded by volunteers for big-sign placements. Submission docId
// (random Firestore-generated) is used as the filename; nothing else is
// writable. Keep reads public so the map can render <img> tags directly.
service firebase.storage {
  match /b/{bucket}/o {
    match /photos/{photoId} {
      allow read: if true;
      allow write: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
